<%- layout("/layouts/boilerplate.ejs") %>

<div class="container list-wrapper">
  <h1 class="mb-4 text-start" style="font-size: 1.75rem;"><i class="fa-solid fa-folder-open text-xs me-2" style="color: var(--accent);"></i> Active Property Listings</h1>
  
  <div class="d-flex flex-column">
    <% for(list of listings){ %>
      <% if (list.approved){ %>
        <div class="management-card">
          
          <div class="management-info">
            <i class="fa-solid fa-hotel"></i>
            <a href="/listing/<%= list.id %>" class="management-title-link">
              <%= list.title %>
            </a>
          </div>
          
          <div class="management-actions">
            <a href="/listing/<%= list.id %>" class="btn-manage-edit" style="background: transparent; color: var(--accent) !important;">
              <i class="fa-solid fa-eye"></i> View
            </a>
            <% if(currUser && currUser._id.toString() === list.owner._id.toString()){ %>
              <a href="/edit/<%= list.id %>" class="btn-manage-edit">
                <i class="fa-solid fa-pen-to-square"></i> Edit
              </a>
            <% } %>
          </div>

        </div>
      <% } %>
    <% } %>
  </div>
</div>